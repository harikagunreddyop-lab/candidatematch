# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key
# USE_ELITE_ATS=1  # optional: use Elite ATS (Claude Sonnet Batches API) for matching

# Apify
APIFY_API_TOKEN=your-apify-token

# Resume Worker
RESUME_WORKER_URL=http://localhost:3001

# Cron
CRON_SECRET=generate-a-random-secret-here

# App (required for mobile builds; used by Capacitor to load the web app)
# In production, set this to your Amplify app URL, e.g.:
# https://master.your-app-id.amplifyapp.com
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Worker
WORKER_SECRET=generate-a-random-secret-here

# Redis (for rate limiting + BullMQ queues)
# Use redis://localhost:6379 for local dev, or your Upstash/ElastiCache URL
REDIS_URL=redis://localhost:6379

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id
