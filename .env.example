# =============================================================================
# CandidateMatch — Environment Variables
# =============================================================================
# Copy to .env and fill in values. Never commit .env or real credentials.
# See docs/ENV_VARIABLES.md for full documentation.
# =============================================================================

# ── Database (Supabase) — REQUIRED ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App URL — REQUIRED for auth, invites, webhooks ───────────────────────────
# Local: http://localhost:3000 | Production: https://your-app.com
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# ── Auth & Security ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=generate-a-random-secret-here
WORKER_SECRET=generate-a-random-secret-here
EMAIL_TRACKING_SECRET=generate-a-random-secret-here

# ── AI (Anthropic) — Required for AI features ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_TIMEOUT_MS=30000

# ── Redis & Queues ──────────────────────────────────────────────────────────
# Local: redis://localhost:6379 | Production: Upstash or ElastiCache URL
REDIS_URL=redis://localhost:6379

# Upstash (optional: cache, rate limit, feature flags)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ── Resume Worker & Autofill ────────────────────────────────────────────────
RESUME_WORKER_URL=http://localhost:3001
# AUTOFILL_ALLOWED_ORIGINS=https://your-app.com

# ── Stripe (Billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# Company plans (optional; add as you configure products)
# STRIPE_COMPANY_STARTER_PRICE_ID=price_xxx
# STRIPE_COMPANY_GROWTH_PRICE_ID=price_xxx
# STRIPE_COMPANY_SCALE_PRICE_ID=price_xxx
# STRIPE_COMPANY_ENTERPRISE_PRICE_ID=price_xxx
# STRIPE_COMPANY_STARTER_MONTHLY=price_xxx
# STRIPE_COMPANY_STARTER_ANNUAL=price_xxx
# STRIPE_COMPANY_PRO_MONTHLY=price_xxx
# STRIPE_COMPANY_PRO_ANNUAL=price_xxx
# STRIPE_COMPANY_ENTERPRISE_MONTHLY=price_xxx
# STRIPE_COMPANY_ENTERPRISE_ANNUAL=price_xxx

# Candidate Pro
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-key
# FROM_EMAIL=CandidateMatch <noreply@yourdomain.com>

# ── Monitoring & Analytics ──────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Feature Flags (env-based) ────────────────────────────────────────────────
# FEATURE_BILLING_ENABLED=true
# FEATURE_EMAIL_ENABLED=true
# FEATURE_AI_MATCHING_ENABLED=true
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=60000

# ── Integrations & Ingest ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# LINKEDIN_CLIENT_ID=xxx
# LINKEDIN_CLIENT_SECRET=xxx
# ASHBY_JOB_BOARD_NAME=your-ashby-job-board-slug
# ASHBY_API_KEY=your-ashby-api-key
# ADZUNA_APP_ID=your-app-id
# ADZUNA_APP_KEY=your-app-key
# ADZUNA_COUNTRY=gb
# OPENAI_API_KEY=sk-xxx

# Ingest scaling (optional; defaults shown)
# INGEST_USE_V3=true
# INGEST_ITEM_CONCURRENCY=50
# INGEST_CONNECTOR_CONCURRENCY=10
# INGEST_UPSERT_BATCH_SIZE=1000
# INGEST_QUALITY_THRESHOLD=40

# ── Build & Deployment ────────────────────────────────────────────────────────
# BUILD_STANDALONE=true
# NODE_ENV=production
# VERCEL_URL and VERCEL_GIT_COMMIT_SHA are set automatically by Vercel

# ── Debug (development only) ────────────────────────────────────────────────
# DEBUG_MATCHING=true
# USE_ELITE_ATS=1
