{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "types": ["chrome"]
  },
  "include": ["src/**/*.ts", "popup.ts"],
  "exclude": ["dist", "node_modules"]
}

