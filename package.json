{
  "name": "candidatematch",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --testPathPattern=route.test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:perf": "playwright test tests/performance",
    "test:a11y": "playwright test tests/a11y",
    "test:all": "npm run test && npm run test:e2e",
    "dev": "next dev",
    "build": "next build",
    "type-check": "tsc --noEmit",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:delete-seed-companies": "npx tsx scripts/delete-seed-companies.ts",
    "db:ingest-company": "npx tsx scripts/ingest-company.ts",
    "worker:dev": "node worker/index.js",
    "worker:jd-extract": "npx tsx scripts/run-jd-extract-worker.ts",
    "ingest:run": "npx tsx scripts/dev/ingest-runner.ts",
    "worker:build": "docker build -t candidatematch-worker ./worker",
    "discovery:run": "npx tsx src/discovery/discover.ts",
    "generate:companies": "npx tsx scripts/generateCompaniesCsv.ts",
    "mobile:prepare": "node scripts/prepare-mobile-webdir.js",
    "mobile:sync": "npm run mobile:prepare && npx cap sync",
    "mobile:ios": "npm run mobile:sync && npx cap open ios",
    "mobile:android": "npm run mobile:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "autoprefixer": "^10.4.0",
    "bullmq": "^5.70.2",
    "class-variance-authority": "^0.7.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.1",
    "ioredis": "^5.10.0",
    "isomorphic-dompurify": "^3.0.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.11.0",
    "next": "^14.2.0",
    "p-map": "^7.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.0",
    "posthog-js": "^1.359.1",
    "posthog-node": "^5.21.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "tailwindcss": "^3.4.0",
    "unpdf": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/chrome": "^0.1.37",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.27.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "@playwright/test": "^1.49.0",
    "@axe-core/playwright": "^4.10.2"
  }
}
